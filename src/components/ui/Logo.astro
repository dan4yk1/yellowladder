<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox={`-2 -2 ${vbWidth} 45`}
  fill="currentColor"
  role="img"
  aria-label={title}
  class={className}
>
  <title>{title}</title>
  {/* Knockout mask: hides the Y wherever the wordmark sits (dilated by a stroke
      so a thin background sliver shows between the "e" and the Y). */}
  <defs>
    <mask id={maskId} maskUnits="userSpaceOnUse" x="-2" y="-2" width="178" height="45">
      <rect x="-2" y="-2" width="178" height="45" fill="white"></rect>
      <g
        transform="translate(14, 15.184)"
        fill="black"
        stroke="black"
        stroke-width={gap}
        stroke-linejoin="round"
      >
        <path transform="translate(-1.05, 22.29)" d={wordA}></path>
        <g transform="translate(72.09, 0)">
          <path transform="translate(-2.26, 22.29)" d={wordB}></path>
        </g>
      </g>
    </mask>
  </defs>
  {/* Y — back shape is the built-in shadow (currentColor), front shape is the
      letter in the accent colour, drawn on top; masked so the "e" knocks a gap */}
  <g mask={`url(#${maskId})`}>
    <svg
      x="0"
      y="0"
      width="22.5"
      height="40.9575"
      viewBox="0.004 0.004 25.27 46"
      overflow="visible"
    >
      <path transform="translate(1.584 41.544)" d={yShadow}></path>
      <path transform="translate(1.584 41.544)" fill={accent} d={yFront}></path>
    </svg>
  </g>
  {/* wordmark: "ellowladder" — shifted left so the "e" overlaps into the Y */}
  <g transform="translate(14, 15.184)">
    <path transform="translate(-1.05, 22.29)" d={wordA}></path>
    <g transform="translate(72.09, 0)">
      <path transform="translate(-2.26, 22.29)" d={wordB}></path>
    </g>
  </g>
  {/* optional ".ai" suffix — Quicksand Bold outlines, flipped onto the baseline */}
  {
    domain && (
      <g
        transform="translate(167, 37.474) scale(0.0307, -0.0307)"
        fill={domainColor}
      >
        <path d={aiPath}></path>
      </g>
    )
  }
</svg>
