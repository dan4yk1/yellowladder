---
// YellowLadder logo: an ascending-steps mark (three right-aligned rounded bars
// that step inward as they rise — growth / ladder rungs) in brand yellow, paired
// with the "YellowLadder" wordmark as LIVE TEXT in the site font (Open Runde).
// Live text keeps the wordmark crisp at any size and lets it inherit the site's
// typography; the mark is inline SVG so the whole logo is ours (no watermark).
//
// Size it via the `class` prop (height-based, e.g. `h-7`). The mark scales to the
// height; the wordmark is sized proportionally alongside it.
export interface Props {
  class?: string;
  /** Accessible label. */
  title?: string;
  /** Mark fill — defaults to brand yellow. Pass "currentColor" for a flat,
   *  single-colour (monochrome) logo. */
  accent?: string;
}

const {
  class: className = "h-7",
  title = "YellowLadder",
  accent = "#f5b50a",
} = Astro.props;
---

<span
  class={`inline-flex items-center gap-0 ${className}`}
  role="img"
  aria-label={title}
>
  {/* Mark — ascending stepped rungs */}
  <svg
    viewBox="0 0 100 100"
    class="h-[85%] w-auto shrink-0"
    fill={accent}
    stroke="currentColor"
    stroke-width="5"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path
      d="M13.5,84.5c0,1.1,0.9,2,2,2h69c1.1,0,2-0.9,2-2v-11c0-1.1-0.9-2-2-2h-69c-1.1,0-2,0.9-2,2V84.5z"
    ></path>
    <path
      d="M32.5,54.5c0,1.1,0.9,2,2,2h50c1.1,0,2-0.9,2-2v-10c0-1.1-0.9-2-2-2h-50c-1.1,0-2,0.9-2,2V54.5z"
    ></path>
    <path
      d="M50.5,25.5c0,1.1,0.9,2,2,2h32c1.1,0,2-0.9,2-2v-10c0-1.1-0.9-2-2-2h-32c-1.1,0-2,0.9-2,2V25.5z"
    ></path>
  </svg>

  {/* Wordmark — live text in Open Runde, dark ink */}
  <span
    class="text-[1.25em] leading-none font-semibold tracking-[-0.03em] text-ink"
  >
    YellowLadder
  </span>
</span>
