---
// Yellowladder wordmark logo — a stylised "Y" glyph overlapping the word
// "ellowladder" (text pre-converted to vector outlines, so no font needed).
// Reconstructed from the original SVG with the Squarespace logo-block wrappers
// (masks, feColorMatrix recolour filters, rects) stripped out.
//
// The source "Y" is a single path made of two overlapping solid shapes: a back
// copy (the built-in drop shadow) and a front copy (the letter itself). We keep
// that original artwork but split it into its two subpaths so they can take
// different fills — `shadow` (the back shape) uses `currentColor` so it adapts
// to the background, and the front shape takes `accent` (the brand yellow). Set
// `accent="currentColor"` for a flat, single-colour logo. Aspect ratio is fixed
// — size with a height/width via the `class` prop.
//
// Unrelated to the marketing site's own brand — kept here as a reusable asset.
export interface Props {
  class?: string;
  /** Accessible label; falls back to the brand name. */
  title?: string;
  /** Front "Y" fill. Use "currentColor" for a flat single-colour logo. */
  accent?: string;
  /** Width of the knockout sliver between the "e" and the Y, in icon units. */
  gap?: number;
  /** Append the ".ai" domain suffix after the wordmark. Vectorised from
   *  Quicksand Bold (the wordmark's typeface) so it's an exact, font-independent
   *  match. Off by default. */
  domain?: boolean;
  /** Fill for the ".ai" suffix. Defaults to currentColor (matches the
   *  wordmark); pass the accent colour to tie it to the yellow Y. */
  domainColor?: string;
}

const {
  class: className = "h-10 w-auto",
  title = "YellowLadder",
  accent = "#f5b50a",
  gap = 5,
  domain = false,
  domainColor = "currentColor",
} = Astro.props;

// Unique per-instance id so multiple logos on one page don't share a mask.
const maskId = `yl-mask-${crypto.randomUUID().slice(0, 8)}`;

// Widen the canvas when the ".ai" suffix is present so it isn't clipped.
const vbWidth = domain ? 213 : 178;

